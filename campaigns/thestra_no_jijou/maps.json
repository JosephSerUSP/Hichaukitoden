    "events": [
      {
        "id": 1,
        "x": 4,
        "y": 2,
        "name": "Engineer Voss",
        "sprite": "assets/sprites/NPC_Voss.png",
        "trigger": "interact",
        "transparent": false,
        "priority": "same",
        "spawn": "Fixed",
        "pages": [
          {
            "condition": "flag:purifier_restored",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "The gauges are steady. Water's flowing, power's holding."
              },
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "You pulled this city back from the edge, Summoner. We won't forget it."
              }
            ]
          },
          {
            "condition": "questStatus:restore_purifier:active",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "The Hydro Core's still dark. Until that Ash Sovereign dies, we choke."
              },
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "Push down there and end it. The purifier won't start itself."
              }
            ]
          },
          {
            "condition": "questStatus:clear_lower_levels:completed",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "Conduit's cleared, but the Core's still corrupted. New orders:"
              },
              {
                "type": "QUEST_OFFER",
                "questId": "restore_purifier"
              }
            ]
          },
          {
            "condition": "default",
            "script": [
              {
                "type": "LABEL",
                "name": "voss_menu"
              },
              {
                "type": "TEXT",
                "speaker": "Engineer Voss",
                "text": "You're up. The lower levels are bleeding corruption into our air and water."
              },
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "questStatus:clear_lower_levels:active",
                "commands": [
                  {
                    "type": "TEXT",
                    "speaker": "Engineer Voss",
                    "text": "Get descending. Mira's people are waiting on a clear path too."
                  }
                ],
                "elseCommands": [
                  {
                    "type": "TEXT",
                    "speaker": "Engineer Voss",
                    "text": "I need someone to go down and thin the corruption."
                  },
                  {
                    "type": "CHOICE",
                    "options": [
                      {
                        "label": "What happened below?",
                        "commands": [
                          {
                            "type": "TEXT",
                            "speaker": "Engineer Voss",
                            "text": "Storm ash reached the depths. Things down there aren't things anymore."
                          },
                          {
                            "type": "JUMP_TO_LABEL",
                            "label": "voss_menu"
                          }
                        ]
                      },
                      {
                        "label": "I'll investigate the lower levels.",
                        "commands": [
                          {
                            "type": "QUEST_OFFER",
                            "questId": "clear_lower_levels"
                          },
                          {
                            "type": "TEXT",
                            "speaker": "Engineer Voss",
                            "text": "Good. Take the intake shaft. Don't come back until it's quiet."
                          }
                        ]
                      },
                      {
                        "label": "Leave",
                        "commands": []
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": 2,
        "x": 6,
        "y": 3,
        "name": "Healer Mira",
        "sprite": "assets/sprites/NPC_Mira.png",
        "trigger": "interact",
        "transparent": false,
        "priority": "same",
        "spawn": "Fixed",
        "pages": [
          {
            "condition": "flag:purifier_restored",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Healer Mira",
                "text": "Our medics reached the lower survivors. Because of you, they live."
              },
              {
                "type": "TEXT",
                "speaker": "Healer Mira",
                "text": "Thestra breathes again. Thank you, Summoner."
              }
            ]
          },
          {
            "condition": "questStatus:aid_survivors:active",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Healer Mira",
                "text": "The path's still blocked? My people can't reach the trapped until you clear it."
              }
            ]
          },
          {
            "condition": "questStatus:aid_survivors:completed",
            "script": [
              {
                "type": "TEXT",
                "speaker": "Healer Mira",
                "text": "You cleared the way. We're moving supplies down now. Bless you."
              }
            ]
          },
          {
            "condition": "default",
            "script": [
              {
                "type": "LABEL",
                "name": "mira_menu"
              },
              {
                "type": "TEXT",
                "speaker": "Healer Mira",
                "text": "Survivors are pinned in the lower shafts. We can't get to them."
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "How can I help?",
                    "commands": [
                      {
                        "type": "TEXT",
                        "speaker": "Healer Mira",
                        "text": "Clear the corruption between here and them. Then my medics go through."
                      },
                      {
                        "type": "QUEST_OFFER",
                        "questId": "aid_survivors"
                      },
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "mira_menu"
                      }
                    ]
                  },
                  {
                    "label": "I'll clear the path.",
                    "commands": [
                      {
                        "type": "QUEST_OFFER",
                        "questId": "aid_survivors"
                      }
                    ]
                  },
                  {
                    "label": "Leave",
                    "commands": []
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": 3,
        "x": 2,
        "y": 4,
        "name": "Hub Gate",
        "sprite": "assets/sprites/gate.png",
        "trigger": "interact",
        "transparent": false,
        "priority": "same",
        "spawn": "Fixed",
        "script": [
          {
            "type": "CONDITIONAL_BRANCH",
            "condition": "questStatus:clear_lower_levels:active, questStatus:aid_survivors:active, questStatus:restore_purifier:active",
            "commands": [
              {
                "type": "TEXT",
                "text": "The intake shaft hums with failing lamps. Your descent begins here."
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Enter Thestra Intake",
                    "commands": [
                      {
                        "type": "TELEPORT"
                      },
                      {
                        "type": "SET_FLAG",
                        "flag": "entered_intake",
                        "value": true
                      }
                    ]
                  },
                  {
                    "label": "Not yet",
                    "commands": []
                  }
                ]
              }
            ],
            "elseCommands": [
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "flag:entered_intake",
                "commands": [
                  {
                    "type": "TEXT",
                    "text": "The intake shaft is open. Return when the city is safe."
                  }
                ],
                "elseCommands": [
                  {
                    "type": "TEXT",
                    "text": "Speak with Voss or Mira before descending. The Hub needs a reason to open the shaft."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
