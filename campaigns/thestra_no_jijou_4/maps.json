        "pages": [
          {
            "condition": "",
            "script": [
              {
                "type": "LABEL",
                "name": "aris_menu"
              },
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "questStatus:the_temple_blight:inactive",
                "commands": [
                  {
                    "type": "TEXT",
                    "speaker": "Elder Aris",
                    "text": "The blight grows stronger each day. The Temple below is the source."
                  },
                  {
                    "type": "TEXT",
                    "speaker": "Elder Aris",
                    "text": "I need a brave soul to investigate. Will you help us?"
                  },
                  {
                    "type": "CHOICE",
                    "options": [
                      {
                        "label": "Accept the quest",
                        "commands": [
                          {
                            "type": "QUEST_OFFER",
                            "questId": "the_temple_blight"
                          },
                          {
                            "type": "TEXT",
                            "speaker": "Elder Aris",
                            "text": "Enter the temple and find the source. Be swift, the blight spares none."
                          },
                          {
                            "type": "JUMP_TO_LABEL",
                            "label": "aris_menu"
                          }
                        ]
                      },
                      {
                        "label": "Not now",
                        "commands": [
                          {
                            "type": "JUMP_TO_LABEL",
                            "label": "aris_menu"
                          }
                        ]
                      }
                    ]
                  }
                ],
                "elseCommands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "questStatus:missing_healer:inactive",
                    "commands": [
                      {
                        "type": "TEXT",
                        "speaker": "Elder Aris",
                        "text": "Our healer Mina went into the temple days ago. No one has seen her."
                      },
                      {
                        "type": "TEXT",
                        "speaker": "Elder Aris",
                        "text": "She may still be alive. Please look for her."
                      },
                      {
                        "type": "CHOICE",
                        "options": [
                          {
                            "label": "I'll find her",
                            "commands": [
                              {
                                "type": "QUEST_OFFER",
                                "questId": "missing_healer"
                              },
                              {
                                "type": "JUMP_TO_LABEL",
                                "label": "aris_menu"
                              }
                            ]
                          },
                          {
                            "label": "Not now",
                            "commands": [
                              {
                                "type": "JUMP_TO_LABEL",
                                "label": "aris_menu"
                              }
                            ]
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "CONDITIONAL_BRANCH",
                        "condition": "questStatus:missing_healer:completed",
                        "commands": [
                          {
                            "type": "CONDITIONAL_BRANCH",
                            "condition": "questStatus:the_three_tokens:inactive",
                            "commands": [
                              {
                                "type": "TEXT",
                                "speaker": "Elder Aris",
                                "text": "Mina is safe, but the blight remains. Ancient texts mention three tokens."
                              },
                              {
                                "type": "TEXT",
                                "speaker": "Elder Aris",
                                "text": "Speak with Mina – she knows the ritual. Retrieve the tokens from the temple depths."
                              },
                              {
                                "type": "SET_FLAG",
                                "flag": "aris_suggested_tokens",
