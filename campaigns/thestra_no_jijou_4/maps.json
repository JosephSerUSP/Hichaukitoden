                                        "type": "CONDITIONAL_BRANCH",
                                        "condition": "flag:cursebeast_defeated",
                                        "commands": [
                                          {
                                            "type": "TEXT",
                                            "speaker": "Elder Aris",
                                            "text": "The storm is lifting! You have saved Thestra. The temple is sealed forever."
                                          },
                                          {
                                            "type": "CALL_COMMON_EVENT",
                                            "commonEventId": 14
                                          },
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "aris_menu"
                                          }
                                        ],
                                        "elseCommands": [
                                          {
                                            "type": "TEXT",
                                            "speaker": "Elder Aris",
                                            "text": "Your deeds are already legend. Rest and prepare for what lies ahead."
                                          },
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "aris_menu"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ],
                        "elseCommands": [
                          {
                            "type": "TEXT",
                            "speaker": "Elder Aris",
                            "text": "The blight grows. Enter the temple and find the source. Also, our healer is missing."
                          },
                          {
                            "type": "JUMP_TO_LABEL",
                            "label": "aris_menu"
                          }
                        ]
                      }
                    ]
                  }
                ]
