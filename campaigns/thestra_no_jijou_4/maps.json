                              {
                                "type": "JUMP_TO_LABEL",
                                "label": "aris_menu"
                              }
                            ],
                            "elseCommands": [
                              {
                                "type": "CONDITIONAL_BRANCH",
                                "condition": "questStatus:the_three_tokens:active",
                                "commands": [
                                  {
                                    "type": "TEXT",
                                    "speaker": "Elder Aris",
                                    "text": "The tokens are spread across the lower floors. Hurry, the blight spreads."
                                  },
                                  {
                                    "type": "JUMP_TO_LABEL",
                                    "label": "aris_menu"
                                  }
                                ],
                                "elseCommands": [
                                  {
