  "14": {
    "name": "Workbench",
    "label": "Workbench",
    "minimapColor": [
      0.8,
      0.5,
      0.1
    ],
    "commands": [
      {
        "type": "COMMENT",
        "text": "SPEC S8 composability proof: crafting authored as pure data. CHOICE -> hasItem checks -> TAKE_ITEM -> formula success roll -> GIVE_ITEM_ID / consolation text. Zero SCRIPT, zero engine Lua."
      },
      {
        "type": "TEXT",
        "text": "A sturdy workbench, cluttered with alembics and etching tools."
      },
      {
        "type": "CHOICE",
        "options": [
          {
            "label": "Brew: Whispered Lessons (Tonic + Ink)",
            "commands": [
              {
                "type": "COMMENT",
                "text": "Recipe: 1x HP Tonic + 1x Sigil Ink -> Whispered Lessons. Ingredient checks are presence-only (hasItem has no count param), so recipes use two distinct items."
              },
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "hasItem:1",
                "commands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "hasItem:2",
                    "commands": [
                      {
                        "cmd": "COMMENT",
                        "text": "Consume first, then roll: flat 75% success chance."
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 1,
                        "count": -1
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 2,
                        "count": -1
                      },
                      {
                        "cmd": "IF",
                        "condition": "random() < 0.75",
                        "then": [
                          {
                            "cmd": "CHANGE_ITEM",
                            "item": 3,
                            "count": 1
                          },
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "Success! You crafted Whispered Lessons."
                          }
                        ],
                        "else": [
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "The attempt fails; the materials are ruined..."
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "TEXT",
                        "text": "You are missing: Sigil Ink."
                      }
                    ]
                  }
                ],
                "elseCommands": [
                  {
                    "type": "TEXT",
                    "text": "You are missing: HP Tonic."
                  }
                ]
              }
            ]
          },
          {
            "label": "Etch: Golden Egg (Mystic Egg + Ink)",
            "commands": [
              {
                "type": "COMMENT",
                "text": "Recipe: 1x Mystic Egg + 1x Sigil Ink -> Golden Egg. Ingredient checks are presence-only (hasItem has no count param), so recipes use two distinct items."
              },
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "hasItem:11",
                "commands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "hasItem:2",
                    "commands": [
                      {
                        "cmd": "COMMENT",
                        "text": "Consume first, then roll: success scales with average party level, 35%..85%."
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 11,
                        "count": -1
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 2,
                        "count": -1
                      },
                      {
                        "cmd": "IF",
                        "condition": "random() < clamp(0.35 + party.avgLevel * 0.05, 0.35, 0.85)",
                        "then": [
                          {
                            "cmd": "CHANGE_ITEM",
                            "item": 12,
                            "count": 1
                          },
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "Success! You crafted Golden Egg."
                          }
                        ],
                        "else": [
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "The attempt fails; the materials are ruined..."
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "TEXT",
                        "text": "You are missing: Sigil Ink."
                      }
                    ]
                  }
                ],
                "elseCommands": [
                  {
                    "type": "TEXT",
                    "text": "You are missing: Mystic Egg."
                  }
                ]
              }
            ]
          },
          {
            "label": "Mix: Glass of Wine (Ale + Stout)",
            "commands": [
              {
                "type": "COMMENT",
                "text": "Recipe: 1x Mug of Ale + 1x Pint of Stout -> Glass of Wine. Ingredient checks are presence-only (hasItem has no count param), so recipes use two distinct items."
              },
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "hasItem:29",
                "commands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "hasItem:30",
                    "commands": [
                      {
                        "cmd": "COMMENT",
                        "text": "Consume first, then roll: a steady hand comes with a full purse: 50% +0.1%/gold, capped 90%."
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 29,
                        "count": -1
                      },
                      {
                        "cmd": "CHANGE_ITEM",
                        "item": 30,
                        "count": -1
                      },
                      {
                        "cmd": "IF",
                        "condition": "random() < clamp(0.5 + session.gold * 0.001, 0.5, 0.9)",
                        "then": [
                          {
                            "cmd": "CHANGE_ITEM",
                            "item": 31,
                            "count": 1
                          },
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "Success! You crafted Glass of Wine."
                          }
                        ],
                        "else": [
                          {
                            "cmd": "EMIT_TEXT",
                            "fallback": "The attempt fails; the materials are ruined..."
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "TEXT",
                        "text": "You are missing: Pint of Stout."
                      }
                    ]
                  }
                ],
                "elseCommands": [
                  {
                    "type": "TEXT",
                    "text": "You are missing: Mug of Ale."
                  }
                ]
              }
            ]
          },
          {
            "label": "Leave",
            "commands": [
              {
                "type": "TEXT",
                "text": "You step away from the workbench."
              }
            ]
          }
        ]
      }
    ]
  },
  "15": {
    "name": "Alicia Talk Hub",
    "commands": [
      {
        "type": "LABEL",
        "name": "alicia_talk_hub"
      },
      {
        "type": "TEXT",
        "text": "(She fiddles with a loose thread on her apron, waiting for you to speak.)",
        "speaker": "Alicia"
      },
      {
        "type": "CHOICE",
        "options": [
          {
            "label": "About Laura",
            "commands": [
              {
                "type": "TEXT",
                "text": "Laura? She’s… she’s amazing. She’s strong, and beautiful, and… and she smells like vanilla and iron. Is that weird? That’s weird. Forget I said that.",
                "speaker": "Alicia"
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Ask about something else.",
                    "commands": [
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "alicia_talk_hub"
                      }
                    ]
                  },
                  {
                    "label": "I should get going.",
                    "commands": []
                  }
                ]
              }
            ]
          },
          {
            "label": "About Shop",
            "commands": [
              {
                "type": "TEXT",
                "text": "I sell things that keep you alive! It makes me happy. Watching people leave with full bags… it means they might come back. That’s nice.",
                "speaker": "Alicia"
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Ask about something else.",
                    "commands": [
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "alicia_talk_hub"
                      }
                    ]
                  },
                  {
                    "label": "I should get going.",
                    "commands": []
                  }
                ]
              }
            ]
          },
          {
            "label": "About You",
            "commands": [
              {
                "type": "TEXT",
                "text": "Me? I’m just Alicia. I like baking. And… I like listening to the rain. The dungeon is scary, but the rain makes it sound like it’s sleeping.",
                "speaker": "Alicia"
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Ask about something else.",
                    "commands": [
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "alicia_talk_hub"
                      }
                    ]
                  },
                  {
                    "label": "I should get going.",
                    "commands": []
                  }
                ]
              }
            ]
          },
          {
            "label": "Ask about Quest",
            "commands": [
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "questStatus:sparkling_gift:completed",
                "commands": [
                  {
                    "type": "TEXT",
                    "text": "I’m going to make this into a necklace. Or maybe a ring? No, a necklace. She doesn’t like rings when she works. Thank you again!",
                    "speaker": "Alicia"
                  },
                  {
                    "type": "JUMP_TO_LABEL",
                    "label": "alicia_talk_hub"
                  }
                ],
                "elseCommands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "questStatus:sparkling_gift:active",
                    "commands": [
                      {
                        "type": "TEXT",
                        "text": "The Glittering Teardrop… please be careful. It’s pretty, but the dungeon is mean. Don’t get hurt for a rock, okay?",
                        "speaker": "Alicia"
                      },
                      {
                        "type": "CONDITIONAL_BRANCH",
                        "condition": "hasItem:24",
                        "commands": [
                          {
                            "type": "TEXT",
                            "text": "You… you found it! Oh, look at it! It’s perfect. It catches the light just like her eyes when she’s happy. Thank you! Thank you so much!",
                            "speaker": "Alicia"
                          },
                          {
                            "type": "CHOICE",
                            "options": [
                              {
                                "label": "Here you go.",
                                "commands": [
                                  {
                                    "type": "QUEST_COMPLETE",
                                    "questId": "sparkling_gift"
                                  },
                                  {
                                    "type": "TEXT",
                                    "text": "I’m going to make this into a necklace. Or maybe a ring? No, a necklace. She doesn’t like rings when she works. Thank you again!",
                                    "speaker": "Alicia"
                                  },
                                  {
                                    "type": "JUMP_TO_LABEL",
                                    "label": "alicia_talk_hub"
                                  }
                                ]
                              }
                            ]
                          }
                        ],
                        "elseCommands": [
                          {
                            "type": "CHOICE",
                            "options": [
                              {
                                "label": "I'm still looking.",
                                "commands": [
                                  {
                                    "type": "JUMP_TO_LABEL",
                                    "label": "alicia_talk_hub"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "TEXT",
                        "text": "Actually… can I ask a favor? It’s about Laura. I want to give her something special. Something that… shines like she does. There’s a crystal, a ‘Glittering Teardrop’, deep in the dungeon. Would you…?",
                        "speaker": "Alicia"
                      },
                      {
                        "type": "CHOICE",
                        "options": [
                          {
                            "label": "I'll find it.",
                            "commands": [
                              {
                                "type": "QUEST_OFFER",
                                "questId": "sparkling_gift"
                              },
                              {
                                "type": "TEXT",
                                "text": "The Glittering Teardrop… please be careful. It’s pretty, but the dungeon is mean. Don’t get hurt for a rock, okay?",
                                "speaker": "Alicia"
                              },
                              {
                                "type": "CONDITIONAL_BRANCH",
                                "condition": "hasItem:24",
                                "commands": [
                                  {
                                    "type": "TEXT",
                                    "text": "You… you found it! Oh, look at it! It’s perfect. It catches the light just like her eyes when she’s happy. Thank you! Thank you so much!",
                                    "speaker": "Alicia"
                                  },
                                  {
                                    "type": "CHOICE",
                                    "options": [
                                      {
                                        "label": "Here you go.",
                                        "commands": [
                                          {
                                            "type": "QUEST_COMPLETE",
                                            "questId": "sparkling_gift"
                                          },
                                          {
                                            "type": "TEXT",
                                            "text": "I’m going to make this into a necklace. Or maybe a ring? No, a necklace. She doesn’t like rings when she works. Thank you again!",
                                            "speaker": "Alicia"
                                          },
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "alicia_talk_hub"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ],
                                "elseCommands": [
                                  {
                                    "type": "CHOICE",
                                    "options": [
                                      {
                                        "label": "I'm still looking.",
                                        "commands": [
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "alicia_talk_hub"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "label": "Maybe later.",
                            "commands": [
                              {
                                "type": "JUMP_TO_LABEL",
                                "label": "alicia_talk_hub"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "label": "That's enough talk for now.",
            "commands": []
          }
        ]
      }
    ]
