  "17": {
    "name": "Laura Talk Hub",
    "commands": [
      {
        "type": "LABEL",
        "name": "laura_talk_hub"
      },
      {
        "type": "TEXT",
        "text": "(She wipes soot from her forehead, giving you a brief moment of attention.)",
        "speaker": "Laura"
      },
      {
        "type": "CHOICE",
        "options": [
          {
            "label": "About Alicia",
            "commands": [
              {
                "type": "TEXT",
                "text": "Alicia? She's... soft. Too soft for this place. But she makes good bread. And she doesn't ask stupid questions. I tolerate her.",
                "speaker": "Laura"
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Ask about something else.",
                    "commands": [
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "laura_talk_hub"
                      }
                    ]
                  },
                  {
                    "label": "I'm going.",
                    "commands": []
                  }
                ]
              }
            ]
          },
          {
            "label": "About Smithing",
            "commands": [
              {
                "type": "TEXT",
                "text": "Fire purifies. Metal obeys. People... people lie. Steel never lies to you. It just is. That's why I like it.",
                "speaker": "Laura"
              },
              {
                "type": "CHOICE",
                "options": [
                  {
                    "label": "Ask about something else.",
                    "commands": [
                      {
                        "type": "JUMP_TO_LABEL",
                        "label": "laura_talk_hub"
                      }
                    ]
                  },
                  {
                    "label": "I'm going.",
                    "commands": []
                  }
                ]
              }
            ]
          },
          {
            "label": "Ask about Quest",
            "commands": [
              {
                "type": "CONDITIONAL_BRANCH",
                "condition": "questStatus:golden_promise:completed",
                "commands": [
                  {
                    "type": "TEXT",
                    "text": "I'll need time to work on this. Check back later. And... thanks.",
                    "speaker": "Laura"
                  },
                  {
                    "type": "JUMP_TO_LABEL",
                    "label": "laura_talk_hub"
                  }
                ],
                "elseCommands": [
                  {
                    "type": "CONDITIONAL_BRANCH",
                    "condition": "questStatus:golden_promise:active",
                    "commands": [
                      {
                        "type": "TEXT",
                        "text": "Find that signet. Don't come back empty-handed.",
                        "speaker": "Laura"
                      },
                      {
                        "type": "CONDITIONAL_BRANCH",
                        "condition": "hasItem:25",
                        "commands": [
                          {
                            "type": "TEXT",
                            "text": "You found it. Hmph. Not bad. The gold is pure... untouched. Give it here.",
                            "speaker": "Laura"
                          },
                          {
                            "type": "CHOICE",
                            "options": [
                              {
                                "label": "Hand it over.",
                                "commands": [
                                  {
                                    "type": "QUEST_COMPLETE",
                                    "questId": "golden_promise"
                                  },
                                  {
                                    "type": "TEXT",
                                    "text": "I'll need time to work on this. Check back later. And... thanks.",
                                    "speaker": "Laura"
                                  },
                                  {
                                    "type": "JUMP_TO_LABEL",
                                    "label": "laura_talk_hub"
                                  }
                                ]
                              }
                            ]
                          }
                        ],
                        "elseCommands": [
                          {
                            "type": "CHOICE",
                            "options": [
                              {
                                "label": "Still looking.",
                                "commands": [
                                  {
                                    "type": "JUMP_TO_LABEL",
                                    "label": "laura_talk_hub"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ],
                    "elseCommands": [
                      {
                        "type": "TEXT",
                        "text": "You're going deep? Listen. Rumor says a rare undead down there wears a golden band. Unmarked, untarnished. I want that signet — new material for my forge, good pay for you. Interested?",
                        "speaker": "Laura"
                      },
                      {
                        "type": "CHOICE",
                        "options": [
                          {
                            "label": "I'll look for it.",
                            "commands": [
                              {
                                "type": "QUEST_OFFER",
                                "questId": "golden_promise"
                              },
                              {
                                "type": "TEXT",
                                "text": "Find that signet. Don't come back empty-handed.",
                                "speaker": "Laura"
                              },
                              {
                                "type": "CONDITIONAL_BRANCH",
                                "condition": "hasItem:25",
                                "commands": [
                                  {
                                    "type": "TEXT",
                                    "text": "You found it. Hmph. Not bad. The gold is pure... untouched. Give it here.",
                                    "speaker": "Laura"
                                  },
                                  {
                                    "type": "CHOICE",
                                    "options": [
                                      {
                                        "label": "Hand it over.",
                                        "commands": [
                                          {
                                            "type": "QUEST_COMPLETE",
                                            "questId": "golden_promise"
                                          },
                                          {
                                            "type": "TEXT",
                                            "text": "I'll need time to work on this. Check back later. And... thanks.",
                                            "speaker": "Laura"
                                          },
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "laura_talk_hub"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ],
                                "elseCommands": [
                                  {
                                    "type": "CHOICE",
                                    "options": [
                                      {
                                        "label": "Still looking.",
                                        "commands": [
                                          {
                                            "type": "JUMP_TO_LABEL",
                                            "label": "laura_talk_hub"
                                          }
                                        ]
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "label": "Not my job.",
                            "commands": [
                              {
                                "type": "JUMP_TO_LABEL",
                                "label": "laura_talk_hub"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
