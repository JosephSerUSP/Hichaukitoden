  "33": {
    "name": "Gate Guard Allow Pass Hub",
    "commands": [
      {
        "type": "LABEL",
        "name": "gate_guard_pass_hub"
      },
      {
        "type": "TEXT",
        "text": "Guild Pass verified. Keep your MP above the red line. Don’t be a hero in there— heroes become stains."
      },
      {
        "type": "CHOICE",
        "options": [
