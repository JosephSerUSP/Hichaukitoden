[
  {
    "id": 1,
    "name": "Item Creation",
    "kind": "crafting",
    "config": {
      "disciplines": [
        {
          "kind": "blacksmithing",
          "label": "Blacksmithing",
          "stat": "atk",
          "description": "Forge weapons and armor using ATK."
        },
        {
          "kind": "tinkering",
          "label": "Tinkering",
          "stat": "asp",
          "description": "Assemble accessories using ASP."
        },
        {
          "kind": "alchemy",
          "label": "Alchemy",
          "stat": "mat",
          "description": "Brew potions and ink using MAT."
        },
        {
          "kind": "cooking",
          "label": "Cooking",
          "stat": "maxHp",
          "description": "Cook foods using Max HP."
        }
      ],
      "alpha": 0.5,
      "yieldFormula": "floor((ingredient1.meta.potency + ingredient2.meta.potency) / 2) + floor(alpha * S)",
      "penaltyFormula": "((ingredient1.meta.craftElement ~= ingredient2.meta.craftElement and ingredient1.meta.craftElement ~= '' and ingredient2.meta.craftElement ~= '') and 15 or 0) + (S < (ingredient1.meta.tier + ingredient2.meta.tier) * 6 and 20 or 0)",
      "anomalyFormula": "random() < 0.05 and 1.5 or 1.0",
      "brackets": [
        {
          "max": 10,
          "tier": 0,
          "name": "Junk"
        },
        {
          "max": 25,
          "tier": 1,
          "name": "Standard"
        },
        {
          "max": 45,
          "tier": 2,
          "name": "Superior"
        },
        {
          "max": 999,
          "tier": 3,
          "name": "Rare"
        }
      ],
      "timing": {
        "initialDelay": 0.005,
        "maxDelay": 10,
        "delayMult": 1,
        "steps": 200
      },
      "terms": {
        "title": "Item Creation",
        "selectDiscipline": "Select Discipline:",
        "selectCrafter": "Select Crafter:",
        "selectIngredients": "Select Ingredients:",
        "yieldText": "Expected Yield: {0}",
        "anomalyText": "CRITICAL ANOMALY DETECTED!",
        "craftBtn": "Craft",
        "cancelBtn": "Back",
        "resultText": "Crafted: {0}!"
      }
    },
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "state", "value": 1 },
        { "cmd": "SET_VAR", "name": "disciplineIdx", "value": 1 },
        { "cmd": "SET_VAR", "name": "crafterIdx", "value": 1 },
        { "cmd": "SET_VAR", "name": "slot", "value": 1 },
        { "cmd": "SET_VAR", "name": "i1Idx", "value": 1 },
        { "cmd": "SET_VAR", "name": "i2Idx", "value": 1 },
        { "cmd": "SET_VAR", "name": "confirmIdx", "value": 1 },
        { "cmd": "SET_VAR", "name": "i1Id", "value": 0 },
        { "cmd": "SET_VAR", "name": "i2Id", "value": 0 },
        { "cmd": "SET_VAR", "name": "rouletteStep", "value": 0 },
        { "cmd": "OPEN_WINDOW", "windowId": "discipline_panel" },
        { "cmd": "SET_LIST", "windowId": "discipline_panel", "listId": "disciplines" },
        { "cmd": "SET_CURSOR", "windowId": "discipline_panel", "index": 1 }
      ],
      "on_select": [
        {
          "cmd": "IF",
          "condition": "v.state == 1 or v.state == nil",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 2 },
            { "cmd": "SET_VAR", "name": "crafterIdx", "value": 1 },
            { "cmd": "CLOSE_WINDOW", "windowId": "discipline_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "crafter_panel" },
            { "cmd": "SET_LIST", "windowId": "crafter_panel", "listId": "party" },
            { "cmd": "SET_CURSOR", "windowId": "crafter_panel", "index": 1 }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 2",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 3 },
            { "cmd": "SET_VAR", "name": "slot", "value": 1 },
            { "cmd": "SET_VAR", "name": "i1Idx", "value": 1 },
            { "cmd": "SET_VAR", "name": "i2Idx", "value": 1 },
            { "cmd": "SET_VAR", "name": "i1Id", "value": 0 },
            { "cmd": "SET_VAR", "name": "i2Id", "value": 0 },
            { "cmd": "CLOSE_WINDOW", "windowId": "crafter_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "ingredient_panel" },
            { "cmd": "SET_LIST", "windowId": "ingredient_panel", "listId": "inventory" },
            { "cmd": "SET_TEXT", "windowId": "ingredient_panel", "text": "Select Ingredient 1" },
            { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": 1 }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            {
              "cmd": "IF",
              "condition": "v.slot == 1",
              "then": [
                { "cmd": "SET_VAR", "name": "i1Id", "value": "v.i1Idx" },
                { "cmd": "SET_VAR", "name": "slot", "value": 2 },
                { "cmd": "SET_TEXT", "windowId": "ingredient_panel", "text": "Select Ingredient 2" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
              ],
              "else": [
                { "cmd": "SET_VAR", "name": "i2Id", "value": "v.i2Idx" },
                { "cmd": "SET_VAR", "name": "confirmIdx", "value": 1 },
                { "cmd": "SET_VAR", "name": "state", "value": 4 },
                { "cmd": "CLOSE_WINDOW", "windowId": "ingredient_panel" },
                { "cmd": "OPEN_WINDOW", "windowId": "confirm_panel" },
                { "cmd": "SET_TEXT", "windowId": "confirm_panel", "text": "Confirm Crafting" },
                { "cmd": "SET_CURSOR", "windowId": "confirm_panel", "index": 1 }
              ]
            }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 4",
          "then": [
            {
              "cmd": "IF",
              "condition": "v.confirmIdx == 2",
              "then": [
                { "cmd": "SET_VAR", "name": "state", "value": 3 },
                { "cmd": "CLOSE_WINDOW", "windowId": "confirm_panel" },
                { "cmd": "OPEN_WINDOW", "windowId": "ingredient_panel" },
                { "cmd": "SET_LIST", "windowId": "ingredient_panel", "listId": "inventory" },
                { "cmd": "SET_TEXT", "windowId": "ingredient_panel", "text": "Select Ingredient 2" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
              ],
              "else": [
                { "cmd": "SET_VAR", "name": "state", "value": 5 },
                { "cmd": "SET_VAR", "name": "rouletteStep", "value": 0 },
                { "cmd": "CLOSE_WINDOW", "windowId": "confirm_panel" },
                { "cmd": "OPEN_WINDOW", "windowId": "roulette_panel" },
                { "cmd": "PLAY_ANIM", "animId": "roulette" }
              ]
            }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 6",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 1 },
            { "cmd": "SET_VAR", "name": "disciplineIdx", "value": 1 },
            { "cmd": "CLOSE_WINDOW", "windowId": "result_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "discipline_panel" },
            { "cmd": "SET_LIST", "windowId": "discipline_panel", "listId": "disciplines" },
            { "cmd": "SET_CURSOR", "windowId": "discipline_panel", "index": 1 }
          ]
        }
      ],
      "on_cancel": [
        {
          "cmd": "IF",
          "condition": "v.state == 2",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 1 },
            { "cmd": "CLOSE_WINDOW", "windowId": "crafter_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "discipline_panel" },
            { "cmd": "SET_LIST", "windowId": "discipline_panel", "listId": "disciplines" },
            { "cmd": "SET_CURSOR", "windowId": "discipline_panel", "index": "v.disciplineIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 2 },
            { "cmd": "CLOSE_WINDOW", "windowId": "ingredient_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "crafter_panel" },
            { "cmd": "SET_LIST", "windowId": "crafter_panel", "listId": "party" },
            { "cmd": "SET_CURSOR", "windowId": "crafter_panel", "index": "v.crafterIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 4",
          "then": [
            { "cmd": "SET_VAR", "name": "state", "value": 3 },
            { "cmd": "SET_VAR", "name": "slot", "value": 2 },
            { "cmd": "CLOSE_WINDOW", "windowId": "confirm_panel" },
            { "cmd": "OPEN_WINDOW", "windowId": "ingredient_panel" },
            { "cmd": "SET_LIST", "windowId": "ingredient_panel", "listId": "inventory" },
            { "cmd": "SET_TEXT", "windowId": "ingredient_panel", "text": "Select Ingredient 2" },
            { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 5 or v.state == 6",
          "then": [
            { "cmd": "SCENE_EVENT", "kind": "pop" }
          ]
        }
      ],
      "on_up": [
        {
          "cmd": "IF",
          "condition": "v.state == 1",
          "then": [
            { "cmd": "SET_VAR", "name": "disciplineIdx", "value": "max(1, v.disciplineIdx - 1)" },
            { "cmd": "SET_CURSOR", "windowId": "discipline_panel", "index": "v.disciplineIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 2",
          "then": [
            { "cmd": "SET_VAR", "name": "crafterIdx", "value": "max(1, v.crafterIdx - 1)" },
            { "cmd": "SET_CURSOR", "windowId": "crafter_panel", "index": "v.crafterIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            {
              "cmd": "IF",
              "condition": "v.slot == 1",
              "then": [
                { "cmd": "SET_VAR", "name": "i1Idx", "value": "max(1, v.i1Idx - 1)" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i1Idx" }
              ],
              "else": [
                { "cmd": "SET_VAR", "name": "i2Idx", "value": "max(1, v.i2Idx - 1)" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
              ]
            }
          ]
        }
      ],
      "on_down": [
        {
          "cmd": "IF",
          "condition": "v.state == 1",
          "then": [
            { "cmd": "SET_VAR", "name": "disciplineIdx", "value": "min(4, v.disciplineIdx + 1)" },
            { "cmd": "SET_CURSOR", "windowId": "discipline_panel", "index": "v.disciplineIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 2",
          "then": [
            { "cmd": "SET_VAR", "name": "crafterIdx", "value": "min(4, v.crafterIdx + 1)" },
            { "cmd": "SET_CURSOR", "windowId": "crafter_panel", "index": "v.crafterIdx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            {
              "cmd": "IF",
              "condition": "v.slot == 1",
              "then": [
                { "cmd": "SET_VAR", "name": "i1Idx", "value": "v.i1Idx + 1" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i1Idx" }
              ],
              "else": [
                { "cmd": "SET_VAR", "name": "i2Idx", "value": "v.i2Idx + 1" },
                { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
              ]
            }
          ]
        }
      ],
      "on_left": [
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            { "cmd": "SET_VAR", "name": "slot", "value": 1 },
            { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i1Idx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 4",
          "then": [
            { "cmd": "SET_VAR", "name": "confirmIdx", "value": "max(1, v.confirmIdx - 1)" },
            { "cmd": "SET_CURSOR", "windowId": "confirm_panel", "index": "v.confirmIdx" }
          ]
        }
      ],
      "on_right": [
        {
          "cmd": "IF",
          "condition": "v.state == 3",
          "then": [
            { "cmd": "SET_VAR", "name": "slot", "value": 2 },
            { "cmd": "SET_CURSOR", "windowId": "ingredient_panel", "index": "v.i2Idx" }
          ]
        },
        {
          "cmd": "IF",
          "condition": "v.state == 4",
          "then": [
            { "cmd": "SET_VAR", "name": "confirmIdx", "value": "min(2, v.confirmIdx + 1)" },
            { "cmd": "SET_CURSOR", "windowId": "confirm_panel", "index": "v.confirmIdx" }
          ]
        }
      ],
      "on_frame": [
        {
          "cmd": "IF",
          "condition": "v.state == 5",
          "then": [
            { "cmd": "WAIT", "duration": 0.05 },
            { "cmd": "SET_VAR", "name": "rouletteStep", "value": "v.rouletteStep + 1" },
            {
              "cmd": "IF",
              "condition": "v.rouletteStep >= 200",
              "then": [
                { "cmd": "SET_VAR", "name": "state", "value": 6 },
                { "cmd": "CLOSE_WINDOW", "windowId": "roulette_panel" },
                { "cmd": "OPEN_WINDOW", "windowId": "result_panel" },
                { "cmd": "SET_TEXT", "windowId": "result_panel", "text": "Crafting complete!" }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "id": "title",
    "name": "Title Screen",
    "kind": "menu",
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "selectedIdx", "value": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "title_frame" },
        { "cmd": "SET_TEXT", "windowId": "title_frame", "text": "\\c[6]HICHAUKITODEN" },
        { "cmd": "OPEN_WINDOW", "windowId": "title_menu" },
        { "cmd": "SET_TEXT", "windowId": "title_menu", "text": "Press ENTER to start" },
        { "cmd": "SET_CURSOR", "windowId": "title_menu", "index": 1 }
      ],
      "on_select": [
        { "cmd": "SCENE_EVENT", "kind": "goto", "scene": "town" }
      ],
      "on_cancel": [
        { "cmd": "SCENE_EVENT", "kind": "quit" }
      ]
    }
  },
  {
    "id": "menu",
    "name": "Main Menu",
    "kind": "menu",
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "opt", "value": 1 },
        { "cmd": "SET_VAR", "name": "subIdx", "value": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "menu_left_panel" },
        { "cmd": "SET_LIST", "windowId": "menu_left_panel", "listId": "menu_options" },
        { "cmd": "SET_CURSOR", "windowId": "menu_left_panel", "index": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "menu_right_panel" },
        { "cmd": "SET_LIST", "windowId": "menu_right_panel", "listId": "party" },
        { "cmd": "OPEN_WINDOW", "windowId": "menu_info_panel" }
      ],
      "on_cancel": [
        { "cmd": "SCENE_EVENT", "kind": "pop" }
      ]
    }
  },
  {
    "id": "items",
    "name": "Items",
    "kind": "menu",
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "idx", "value": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "items_left_panel" },
        { "cmd": "SET_LIST", "windowId": "items_left_panel", "listId": "inventory" },
        { "cmd": "SET_CURSOR", "windowId": "items_left_panel", "index": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "items_info_panel" }
      ],
      "on_cancel": [
        { "cmd": "SCENE_EVENT", "kind": "pop" }
      ]
    }
  },
  {
    "id": "status",
    "name": "Status",
    "kind": "menu",
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "idx", "value": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "status_panel" }
      ],
      "on_cancel": [
        { "cmd": "SCENE_EVENT", "kind": "pop" }
      ]
    }
  }
]
