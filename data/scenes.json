    "id": "shop",
    "name": "Shop",
    "kind": "menu",
    "goldenScript": [
      { "key": "down" },
      { "key": "up" },
      { "key": "escape" }
    ],
    "hooks": {
      "on_enter": [
        {
          "cmd": "SET_VAR",
          "name": "idx",
          "value": 1
        },
        {
          "cmd": "SET_VAR",
          "name": "count",
          "value": 0
        },
        {
          "cmd": "OPEN_WINDOW",
          "windowId": "shop_header"
        },
        {
          "cmd": "OPEN_WINDOW",
          "windowId": "shop_list"
        },
        {
          "cmd": "SET_LIST",
          "windowId": "shop_list",
          "listId": "shop_items"
        },
        {
          "cmd": "SET_CURSOR",
          "windowId": "shop_list",
          "index": 1
        },
        {
          "cmd": "OPEN_WINDOW",
          "windowId": "shop_info"
        }
      ],
      "on_up": [
        {
          "cmd": "IF",
          "condition": "v.idx > 1",
          "then": [
            {
              "cmd": "SET_VAR",
              "name": "idx",
              "value": "v.idx - 1"
            }
          ]
        }
      ],
      "on_down": [
        {
          "cmd": "IF",
          "condition": "v.count and v.idx < v.count",
          "then": [
            {
              "cmd": "SET_VAR",
              "name": "idx",
              "value": "v.idx + 1"
            }
          ]
        }
      ],
      "on_cancel": [
        {
          "cmd": "SCENE_EVENT",
          "kind": "pop"
        }
      ],
      "on_select": [
        {
          "cmd": "IF",
          "condition": "v.count > 0 and v.items[v.idx] and session.gold >= v.items[v.idx].cost",
          "then": [
            {
              "cmd": "GAIN_GOLD",
              "amount": "-v.items[v.idx].cost"
            },
            {
              "cmd": "SET_VAR",
              "name": "pendingItem",
              "value": "v.items[v.idx].id"
            }
          ]
        }
      ]
    }
  }
]