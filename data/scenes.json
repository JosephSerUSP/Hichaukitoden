          "description": "Cook foods using Max HP."
        }
      ],
      "alpha": 0.5,
      "yieldFormula": "floor((ingredient1.meta.potency + ingredient2.meta.potency) / 2) + floor(alpha * S)",
      "penaltyFormula": "((ingredient1.meta.craftElement ~= ingredient2.meta.craftElement and ingredient1.meta.craftElement ~= '' and ingredient2.meta.craftElement ~= '') and 15 or 0) + (S < (ingredient1.meta.tier + ingredient2.meta.tier) * 6 and 20 or 0)",
      "anomalyFormula": "random() < 0.05 and 1.5 or 1.0",
      "brackets": [
        {
          "max": 10,
          "tier": 0,
          "name": "Junk"
        },
        {
          "max": 25,
          "tier": 1,
          "name": "Standard"
        },
        {
          "max": 45,
          "tier": 2,
          "name": "Superior"
        },
        {
          "max": 999,
          "tier": 3,
          "name": "Rare"
        }
      ],
      "timing": {
        "initialDelay": 0.005,
        "maxDelay": 10,
        "delayMult": 1,
        "steps": 200
