[
  {
    "id": 1,
    "name": "Item Creation",
    "kind": "crafting",
    "config": {
      "disciplines": [
        {
          "kind": "blacksmithing",
          "label": "Blacksmithing",
          "stat": "atk",
          "description": "Forge weapons and armor using ATK."
        },
        {
          "kind": "tinkering",
          "label": "Tinkering",
          "stat": "asp",
          "description": "Assemble accessories using ASP."
        },
        {
          "kind": "alchemy",
          "label": "Alchemy",
          "stat": "mat",
          "description": "Brew potions and ink using MAT."
        },
        {
          "kind": "cooking",
          "label": "Cooking",
          "stat": "maxHp",
          "description": "Cook foods using Max HP."
        }
      ],
      "alpha": 0.5,
      "yieldFormula": "floor((i1.meta.potency + i2.meta.potency) / 2) + floor(alpha * S)",
      "penaltyFormula": "((i1.meta.craftElement ~= i2.meta.craftElement and i1.meta.craftElement ~= '' and i2.meta.craftElement ~= '') and 15 or 0) + (S < (i1.meta.tier + i2.meta.tier) * 6 and 20 or 0)",
      "anomalyFormula": "random() < 0.05 and 1.5 or 1.0",
      "brackets": [
        {
          "max": 10,
          "tier": 0,
          "name": "Junk"
        },
        {
          "max": 25,
          "tier": 1,
          "name": "Standard"
        },
        {
          "max": 45,
          "tier": 2,
          "name": "Superior"
        },
        {
          "max": 999,
          "tier": 3,
          "name": "Rare"
        }
      ],
      "timing": {
        "initialDelay": 0.005,
        "maxDelay": 10,
        "delayMult": 1,
        "steps": 200
      },
      "terms": {
        "title": "Item Creation",
        "selectDiscipline": "Select Discipline:",
        "selectCrafter": "Select Crafter:",
        "selectIngredients": "Select Ingredients:",
        "yieldText": "Expected Yield: {0}",
        "anomalyText": "CRITICAL ANOMALY DETECTED!",
        "craftBtn": "Craft",
        "cancelBtn": "Back",
        "resultText": "Crafted: {0}!"
      }
    },
    "hooks": {
      "on_enter": [
        { "cmd": "SET_VAR", "name": "state", "value": 1 },
        { "cmd": "SET_VAR", "name": "selectedDisciplineIdx", "value": 1 },
        { "cmd": "SET_VAR", "name": "selectedCrafterIdx", "value": 1 },
        { "cmd": "SET_VAR", "name": "selectedIngredient1Idx", "value": 1 },
        { "cmd": "SET_VAR", "name": "selectedIngredient2Idx", "value": 1 },
        { "cmd": "SET_VAR", "name": "cursorIngredientSlot", "value": 1 },
        { "cmd": "SET_VAR", "name": "confirmOptionIdx", "value": 1 },
        { "cmd": "OPEN_WINDOW", "windowId": "craftingDiscipline" },
        { "cmd": "SET_LIST", "windowId": "craftingDiscipline", "listId": "disciplines" }
      ],
      "on_select": [
        { "cmd": "IF", "condition": "v.state == 1", "then": [ { "cmd": "SET_VAR", "name": "state", "value": 2 }, { "cmd": "SET_VAR", "name": "selectedCrafterIdx", "value": 1 } ], "else": [
          { "cmd": "IF", "condition": "v.state == 2", "then": [ { "cmd": "CRAFT_SELECT_CRAFTER" }, { "cmd": "SET_VAR", "name": "state", "value": 3 }, { "cmd": "SET_VAR", "name": "cursorIngredientSlot", "value": 1 } ], "else": [
            { "cmd": "IF", "condition": "v.state == 3", "then": [
               { "cmd": "CRAFT_SELECT_INGREDIENT" }
            ], "else": [
              { "cmd": "IF", "condition": "v.state == 4", "then": [
                 { "cmd": "IF", "condition": "v.confirmOptionIdx == 2", "then": [ { "cmd": "SET_VAR", "name": "state", "value": 3 }, { "cmd": "SET_VAR", "name": "cursorIngredientSlot", "value": 2 } ], "else": [
                     { "cmd": "CRAFT_EVAL_POOL" },
                     { "cmd": "SET_VAR", "name": "state", "value": 5 },
                     { "cmd": "WAIT", "duration": 2.5 },
                     { "cmd": "CRAFT_GIVE_RESULT" },
                     { "cmd": "SET_VAR", "name": "state", "value": 6 }
                 ] }
              ], "else": [
                { "cmd": "IF", "condition": "v.state == 6", "then": [ { "cmd": "CRAFT_RESET" } ], "else": [] }
              ] }
            ] }
          ] }
        ] }
      ],
      "on_cancel": [
        { "cmd": "IF", "condition": "v.state == 1", "then": [ { "cmd": "SCENE_EVENT", "kind": "pop" } ], "else": [
          { "cmd": "IF", "condition": "v.state == 2", "then": [ { "cmd": "SET_VAR", "name": "state", "value": 1 } ], "else": [
            { "cmd": "IF", "condition": "v.state == 3", "then": [ { "cmd": "SET_VAR", "name": "state", "value": 2 } ], "else": [
              { "cmd": "IF", "condition": "v.state == 4", "then": [ { "cmd": "SET_VAR", "name": "state", "value": 3 }, { "cmd": "SET_VAR", "name": "cursorIngredientSlot", "value": 2 } ], "else": [
                 { "cmd": "IF", "condition": "v.state == 6", "then": [ { "cmd": "CRAFT_RESET" } ], "else": [] }
              ] }
            ] }
          ] }
        ] }
      ]
    }
  }
]